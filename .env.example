# Copy to .env and fill in. NEVER commit .env.

# Bearer token required on /api and /mcp. Generate a strong one, e.g.:
#   openssl rand -hex 32
AUTH_TOKEN=

# Cloudflare Tunnel token (remotely-managed tunnel).
# Get it from: Cloudflare Zero Trust dashboard → Networks → Tunnels →
#   create/select tunnel → Docker → copy the value after `--token`.
# See DEPLOY.md for the full step-by-step.
TUNNEL_TOKEN=

# Public HTTPS origin of the server. REQUIRED for the claude.ai connector —
# it is used as the OAuth issuer / resource identifier, so it must match the
# URL claude.ai talks to.
PUBLIC_URL=https://appstore-scraper.agence-zen.com

# Optional: dedicated HMAC secret for signing OAuth tokens. Defaults to
# AUTH_TOKEN when empty. Set + rotate independently if you wish.
OAUTH_SIGNING_SECRET=
